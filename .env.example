# Copy to .env and fill in values. Do not commit .env with real secrets.

# --- Supabase (required for multi-user cloud persistence) ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=
SUPABASE_JWT_AUDIENCE=authenticated

# --- Frontend (Vite; set at build time for production) ---
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Browser -> API (local dev: http://127.0.0.1:8000 ; prod: https://your-api.example.com)
VITE_API_BASE_URL=

# --- Local vs cloud agent history / scheduler / notepad ---
# 0 or unset = use Supabase for runs, scheduler sync, notepad (apply db/migrations in Supabase SQL editor).
# 1 = local JSON under memory/local_runs, memory/scheduled_jobs, memory/notes
LOCAL_RUN_STORE=0

# --- CORS (production: list every frontend origin, comma-separated) ---
# CORS_ORIGINS=https://app.example.com,https://www.example.com

# --- Gmail (per-user OAuth; credentials.json = Web client JSON at project root) ---
# Must match Google Cloud "Authorized redirect URI" exactly.
# GMAIL_OAUTH_REDIRECT_URI=https://api.example.com/api/mail/oauth/callback
# MAIL_OAUTH_SUCCESS_URL=https://app.example.com/agent?mail_connected=1

# --- Optional: models, guests, admin ---
# OLLAMA_BASE_URL=
# SAVE_LOCAL_SESSIONS=0
# ADMIN_USER_IDS=
